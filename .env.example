# ============================================
# Deep Research Platform - Environment Template
# Copy to .env and fill in values
# ============================================

# ---------- General ----------
APP_NAME=deep-research
APP_ENV=development
DEBUG=true
LOG_LEVEL=DEBUG

# ---------- Backend ----------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_WORKERS=1
BACKEND_RELOAD=true
API_V1_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:3000", "http://localhost:4000"]
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32

# ---------- PostgreSQL ----------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=deep_research
POSTGRES_PASSWORD=deep_research_dev
POSTGRES_DB=deep_research
POSTGRES_POOL_SIZE=10
POSTGRES_MAX_OVERFLOW=20
POSTGRES_ECHO=false

# ---------- Redis ----------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_MAX_CONNECTIONS=20
REDIS_DEFAULT_TTL=3600
REDIS_KEY_PREFIX=dr

# ---------- AI / LLM (future phase) ----------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=4096
OPENAI_TEMPERATURE=0.7

# ---------- SSE (future phase) ----------
SSE_RETRY_TIMEOUT=3000
SSE_MAX_CONNECTIONS=100

# ---------- Rate Limiting ----------
RATE_LIMIT_ENABLED=false
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# ---------- Frontend ----------
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_ENABLE_SSE=false
NEXT_PUBLIC_ENABLE_OBSERVABILITY=false

# ============================================
# Deep Research Platform - Frontend Dockerfile (Development)
# ============================================

FROM node:20-alpine

WORKDIR /app

# Install dependencies first (layer caching)
COPY package.json package-lock.json* ./
RUN npm ci

# Copy source (will be overridden by volume mount)
COPY . .

EXPOSE 3000

CMD ["npm", "run", "dev"]
